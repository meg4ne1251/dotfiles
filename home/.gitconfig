# ~/.gitconfig - tracked git configuration
# Name and email live in ~/.gitconfig.local (git-ignored, machine-specific).
[include]
	path = ~/.gitconfig.local

[core]
	editor = vim
	autocrlf = input

[init]
	defaultBranch = main

[color]
	ui = auto
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red
	new = green
	whitespace = red reverse
[color "status"]
	added = green
	changed = yellow
	untracked = red

[diff]
	algorithm = histogram

[alias]
	st = status
	co = checkout
	br = branch
	cm = commit
	lg = log --oneline --graph --decorate --all
	pushf = push --force-with-lease

[pull]
	rebase = false
[merge]
	conflictstyle = diff3
[push]
	autoSetupRemote = true
[fetch]
	prune = true
[rebase]
	autosquash = true

# Authenticate to GitHub/Gist over HTTPS using the gh CLI's credential helper.
# (The empty `helper =` first clears any inherited helpers.)
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
